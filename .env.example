HYPERLIQUID_TESTNET_PRIVATE_KEY=0x...
TESTNET_WALLET_ADDRESS=0x...

# HyperCore /info and /exchange must go through Hyperliquid's official API —
# /exchange is validator-routed and not exposed on third-party RPC.
HL_BASE_URL=https://api.hyperliquid-testnet.xyz
HL_WS_URL=wss://api.hyperliquid-testnet.xyz/ws

# HyperEVM JSON-RPC. Get a private endpoint at https://console.chainstack.com
# and append the path you need: /evm (default, hl-node-compliant) or /nanoreth
# (system transactions included). Chain ID 999.
HL_EVM_URL=https://hyperliquid-testnet.core.chainstack.com/YOUR_TOKEN/evm
# Mainnet variant: https://hyperliquid-mainnet.core.chainstack.com/YOUR_TOKEN/evm
